# ============================================================
# 통합 포인트 관리 시스템 - 환경 변수 예시
# 실제 운영 시 .env 파일에 복사 후 모든 값을 반드시 변경하세요
# ============================================================

# ────────────────────────────────────────────────
# 서버 설정
# ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ────────────────────────────────────────────────
# 데이터베이스 (AWS RDS PostgreSQL)
# ────────────────────────────────────────────────
DB_HOST=localhost                          # RDS 엔드포인트 (예: my-db.xxxx.ap-northeast-2.rds.amazonaws.com)
DB_PORT=5432
DB_NAME=pointdb
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD      # 반드시 강력한 비밀번호로 변경
DB_SSL=false                               # RDS 연결 시 true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_MIN=5

# ────────────────────────────────────────────────
# Redis (AWS ElastiCache)
# ────────────────────────────────────────────────
REDIS_HOST=localhost                        # ElastiCache 엔드포인트
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ────────────────────────────────────────────────
# JWT 인증
# ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_KEY_MINIMUM  # openssl rand -base64 64
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=30

# ────────────────────────────────────────────────
# 카카오 소셜 로그인
# https://developers.kakao.com 에서 앱 등록 후 발급
# ────────────────────────────────────────────────
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CALLBACK_URL=https://yourdomain.com/api/v1/auth/kakao/callback

# ────────────────────────────────────────────────
# 네이버 소셜 로그인
# https://developers.naver.com 에서 앱 등록 후 발급
# ────────────────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_CALLBACK_URL=https://yourdomain.com/api/v1/auth/naver/callback

# ────────────────────────────────────────────────
# 통신사 본인인증
# MOCK: 개발 환경 (실제 인증 없음)
# NICE: NICE 본인인증 서비스 (계약 필요)
# ────────────────────────────────────────────────
TELECOM_PROVIDER=MOCK
NICE_SITE_CODE=                            # NICE 사이트 코드
NICE_SITE_PASSWORD=                        # NICE 사이트 패스워드

# ────────────────────────────────────────────────
# CORS 및 프론트엔드
# ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,https://yourdomain.com
FRONTEND_URL=http://localhost:3001

# ────────────────────────────────────────────────
# 외부 연동 API (기본 키 - 관리자 페이지에서 사이트별 발급 권장)
# ────────────────────────────────────────────────
EXTERNAL_API_KEY=CHANGE_ME_EXTERNAL_API_KEY

# ────────────────────────────────────────────────
# AWS 설정 (ECS/Fargate 배포 시)
# ────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012
ECR_BACKEND_REPO=your-account.dkr.ecr.ap-northeast-2.amazonaws.com/point-backend
ECR_FRONTEND_REPO=your-account.dkr.ecr.ap-northeast-2.amazonaws.com/point-frontend
ECS_CLUSTER=point-management-cluster
ECS_BACKEND_SERVICE=point-backend-service
ECS_FRONTEND_SERVICE=point-frontend-service
